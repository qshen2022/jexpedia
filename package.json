{
  "name": "jexpedia",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev -w @jexpedia/api",
    "dev:web": "npm run dev -w @jexpedia/web",
    "build": "npm run build -w @jexpedia/web",
    "start": "npm run start -w @jexpedia/web",
    "lint": "npm run lint -w @jexpedia/web",
    "seed": "npm run seed -w @jexpedia/api"
  }
}
